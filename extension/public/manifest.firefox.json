{
  "manifest_version": 2,
  "name": "Tomari, Manga Tracker",
  "version": "0.2.0",
  "description": "Tracks manga reading progress on supported sites.",
  "permissions": ["storage", "<all_urls>"],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "icons": {
    "512": "icon-512.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icon-512.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "tomari-manga-tracker@kdonohoue.com",
      "strict_min_version": "120.0",
      "data_collection_permissions": {
        "required": [
          "browsingActivity",
          "websiteContent"
        ]
      }
    }
  }
}
