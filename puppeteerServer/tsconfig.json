{
    "compilerOptions": {
      "module": "nodenext",
      "resolveJsonModule": true,
      "esModuleInterop": true,
      "target": "esnext",
      "moduleResolution": "nodenext",
      "sourceMap": true,
      "outDir": "dist",
      "types": ["node", "chrome", "firefox-webext-browser"]
    },
    "exclude": [
        "puppeteerScripts/deprecated",
        "node_modules"
    ]
    // "lib": ["ES2018"]
}