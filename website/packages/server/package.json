{
  "name": "server",
  "type": "module",
  "scripts": {
    "dev": "cp ../../.env.dev .dev.vars && wrangler dev",
    "deploy": "wrangler secret bulk ../../.env.production -e production && wrangler deploy -e production --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.5.5",
    "@better-auth/sso": "^1.5.5",
    "@block65/webcrypto-web-push": "^1.0.2",
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "wrangler": "^4.73.0"
  }
}