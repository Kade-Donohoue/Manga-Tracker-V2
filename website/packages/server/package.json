{
  "name": "server",
  "type": "module",
  "scripts": {
    "dev": "cp ../../.env.dev .dev.vars && wrangler dev",
    "deploy": "wrangler secret bulk ../../.env.production -e production && wrangler deploy -e production --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.11",
    "@better-auth/sso": "^1.6.11",
    "@block65/webcrypto-web-push": "^1.0.2",
    "@hono/zod-validator": "^0.8.0",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/node": "^25.7.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "wrangler": "^4.90.1"
  }
}